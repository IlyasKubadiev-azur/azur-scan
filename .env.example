# Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=dev-only-change-me-to-50-random-bytes
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# Database (Docker compose)
DATABASE_URL=postgres://azurscan:azurscan@postgres:5432/azurscan
POSTGRES_DB=azurscan
POSTGRES_USER=azurscan
POSTGRES_PASSWORD=azurscan

# JWT secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
USER_JWT_SECRET=change-me-user-jwt-secret
AGENT_JWT_SECRET=change-me-agent-jwt-secret

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=False

# CORS (comma-separated origins for SPA, leave empty if no separate frontend)
CORS_ALLOWED_ORIGINS=

# Logging
LOG_LEVEL=INFO

# Agent defaults (override via env, used in enrollment response).
# 15s heartbeat = near-instant rescan command pickup with negligible load
# at MVP-scale (tens of devices). Bump to 60-120 if you reach 1000+ devices.
AGENT_HEARTBEAT_INTERVAL_S=15
AGENT_FULL_SCAN_INTERVAL_H=6
