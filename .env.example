# Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=dev-only-change-me-to-50-random-bytes
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,web

# Database (Docker compose)
DATABASE_URL=postgres://azurscan:azurscan@postgres:5432/azurscan
POSTGRES_DB=azurscan
POSTGRES_USER=azurscan
POSTGRES_PASSWORD=azurscan

# JWT secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
USER_JWT_SECRET=change-me-user-jwt-secret
AGENT_JWT_SECRET=change-me-agent-jwt-secret

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=False

# CORS (comma-separated origins for SPA, leave empty if no separate frontend)
CORS_ALLOWED_ORIGINS=

# =============================================================================
# LDAP / Active Directory  (optional, set LDAP_ENABLED=True to enable)
#
# Two effects when enabled:
#   1. Users can log into /admin/ with their domain credentials.
#   2. The `sync_ldap_users` management command pulls all enabled accounts
#      from AD into the Django User table — they then appear in the
#      "Current owner" dropdown on assets. Run it manually:
#        docker compose exec web python manage.py sync_ldap_users
#      Or schedule it via Celery beat (apps/accounts/tasks.py).
# =============================================================================
LDAP_ENABLED=False

# LDAPS is strongly recommended in production. For internal LAN testing
# you can use ldap:// on port 389.
AUTH_LDAP_SERVER_URI=ldaps://dc.azurgames.local:636

# Read-only service account that can enumerate users in the search base.
AUTH_LDAP_BIND_DN=CN=svc-azurscan,OU=Service Accounts,DC=azurgames,DC=local
AUTH_LDAP_BIND_PASSWORD=<bind-password>

# Where to look for users — be specific. Searching the root DC=… is slow
# and may pull service accounts you don't want as asset owners.
AUTH_LDAP_USER_SEARCH_BASE=OU=Users,DC=azurgames,DC=local

# Optional, for future group-based RBAC sync
AUTH_LDAP_GROUP_SEARCH_BASE=OU=Groups,DC=azurgames,DC=local

# Logging
LOG_LEVEL=INFO

# Agent defaults (override via env, used in enrollment response).
# 15s heartbeat = near-instant rescan command pickup with negligible load
# at MVP-scale (tens of devices). Bump to 60-120 if you reach 1000+ devices.
AGENT_HEARTBEAT_INTERVAL_S=15
AGENT_FULL_SCAN_INTERVAL_H=6
